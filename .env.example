APP_ENV=dev

POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app

DATABASE_URL=postgresql://app:change-me@db:5432/app

# Runtime DB role (app_rt) — non-owner role the request path uses so RLS is enforced.
# The migration creates the role with APP_RT_PASSWORD; keep it in sync with the DSN.
APP_RT_PASSWORD=change-me-rt
RUNTIME_DATABASE_URL=postgresql://app_rt:change-me-rt@db:5432/app

# Local JWT issuer. Generate a strong secret, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Claude API (get a key at https://platform.claude.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-haiku-4-5

# Guardrail sidecar (llm-guard). AUTH_TOKEN secures the sidecar API; the app sends
# it as a Bearer token. Generate a strong value, e.g. `openssl rand -hex 32`.
GUARDRAILS_URL=http://llm-guard-api:8000
GUARDRAILS_AUTH_TOKEN=change-me-guardrails-token
